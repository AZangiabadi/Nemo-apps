# Public hostname used by Caddy. Use localhost for a local container test.
TOOLS_NEMO_DOMAIN=tools.example.edu
NEMO_ENV=production

# NEMO API location. Users supply per-job API tokens in the web forms.
NEMO_BASE_URL=https://nemo.cni.columbia.edu
NEMO_TIMEZONE=America/New_York

# Generate these values; do not commit the real values.
NEMO_APP_ACCESS_PASSWORD=replace-with-a-long-password
NEMO_FLASK_SECRET_KEY=replace-with-at-least-32-random-bytes
NEMO_JOB_SECRET_KEY=replace-with-a-fernet-key

# Optional: enables the read-only jumbotron without asking for a token.
NEMO_JUMBOTRON_API_TOKEN=

NEMO_JUMBOTRON_REFRESH_SECONDS=15
NEMO_JUMBOTRON_CACHE_SECONDS=15
NEMO_JUMBOTRON_SCROLL_STEP_PX=1
NEMO_JUMBOTRON_SCROLL_INTERVAL_MS=50
NEMO_METADATA_CACHE_SECONDS=21600
NEMO_OUTPUT_RETENTION_DAYS=14
NEMO_JOB_STALE_SECONDS=3600
